# Loaded automatically on server start (see src/index.ts: import "dotenv/config").
# MySQL (required)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/eshop"

# --- Email (optional): bank-transfer order summary ---
# Local dev: use Ethereal (fake inbox + preview URL). First run creates a throwaway
# account in memory; check backend logs for [Ethereal] lines.
SMTP_USE_ETHEREAL=true

# Or use real SMTP instead (set SMTP_USE_ETHEREAL=false or remove it):
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="AI Testing Shop <noreply@example.com>"
