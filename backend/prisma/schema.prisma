datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Currency {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  createdAt DateTime @default(now())
  products  Product[]
  orders    Order[]
  cartItems CartItem[]
  orderItems OrderItem[]
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      UserRole  @default(CUSTOMER)
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum UserRole {
  ADMIN
  CUSTOMER
  TESTER
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  price       Int
  inStock     Int
  active      Boolean    @default(true)
  currencyId  Int?
  currency    Currency?  @relation(fields: [currencyId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  orderItems  OrderItem[]
  cartItems   CartItem[]
}

model Order {
  id                Int           @id @default(autoincrement())
  user              User          @relation(fields: [userId], references: [id])
  userId            Int
  total             Int
  status            OrderStatus   @default(PENDING)
  currencyId        Int?
  currency          Currency?     @relation(fields: [currencyId], references: [id])
  customerEmail     String
  customerFirstName String
  customerLastName  String
  customerPhone     String
  addressLine1      String?
  addressLine2      String?
  city              String?
  postalCode        String?
  country           String?
  paymentMethod     PaymentMethod
  // Browser cart session that placed this order; used to clear the correct cart after payment.
  guestCartKey      String?       @db.VarChar(64)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             OrderItem[]
}

enum PaymentMethod {
  BANK_TRANSFER
  PAYMENT_GATEWAY
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model OrderItem {
  id             Int     @id @default(autoincrement())
  order          Order   @relation(fields: [orderId], references: [id])
  orderId        Int
  product        Product @relation(fields: [productId], references: [id])
  productId      Int
  quantity       Int
  unitPrice      Int
  currencyId     Int?
  currency       Currency? @relation(fields: [currencyId], references: [id])
}

model CartItem {
  id         Int      @id @default(autoincrement())
  cartKey    String   @db.VarChar(64)
  product    Product  @relation(fields: [productId], references: [id])
  productId  Int
  quantity   Int
  currencyId Int?
  currency   Currency? @relation(fields: [currencyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([cartKey, productId], name: "cartKey_productId")
}

model FaultConfig {
  key         String   @id
  name        String
  description String
  level       FaultLevel
  enabled     Boolean  @default(false)
  latencyMs   Int?
  failureRate Float?
  updatedAt   DateTime @updatedAt
}

enum FaultLevel {
  UI
  API
  Unit
}
